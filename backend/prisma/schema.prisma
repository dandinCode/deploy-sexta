generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id        String   @id @default(cuid())
  state     Json
  status    GameStatus @default(DRAFT)
  score     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GameStatus {
  DRAFT
  PLAYING
  FINISHED
}
